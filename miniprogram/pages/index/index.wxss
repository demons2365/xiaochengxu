/* pages/index/index.wxss */
.container {
  min-height: 100vh;
  padding: 30rpx;
  box-sizing: border-box;
}

/* еӨҙйғЁ */
.header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0;
}
.logo {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 20rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #0066ff, #00ccff);
}
.title {
  font-size: 44rpx;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 10rpx;
}
.subtitle {
  font-size: 28rpx;
  color: #8888aa;
}

/* еҚЎзүҮ */
.card {
  background: linear-gradient(135deg, #12122a, #1a1a3a);
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid rgba(0, 102, 255, 0.2);
}
.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #ffffff;
  margin-bottom: 20rpx;
}

/* иҫ“е…ҘжЎ?*/
.config-input {
  width: 100%;
  min-height: 180rpx;
  background: #0a0a20;
  border: 2rpx solid #2a2a5a;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 28rpx;
  color: #e0e0e0;
  box-sizing: border-box;
  line-height: 1.6;
}
.config-input::placeholder {
  color: #555577;
}
.config-input:focus {
  border-color: #0066ff;
}
.char-count {
  text-align: right;
  font-size: 24rpx;
  color: #555577;
  margin-top: 10rpx;
}

/* дёҠдј еҢәеҹҹ */
.upload-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 160rpx;
  background: #0a0a20;
  border: 2rpx dashed #2a2a5a;
  border-radius: 16rpx;
  cursor: pointer;
}
.upload-area:active {
  border-color: #0066ff;
  background: #0a0a30;
}
.upload-icon {
  width: 48rpx;
  height: 48rpx;
  margin-bottom: 10rpx;
}
.upload-text {
  font-size: 26rpx;
  color: #6666aa;
}

/* зӨәдҫӢж Үзӯҫ */
.examples {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}
.example-tag {
  padding: 12rpx 24rpx;
  background: #0a0a20;
  border: 2rpx solid #2a2a5a;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #88aaff;
  cursor: pointer;
}
.example-tag:active {
  background: #1a1a40;
  border-color: #0066ff;
}

/* дј°д»·жҢүй’® */
.estimate-btn {
  width: 100%;
  height: 100rpx;
  line-height: 100rpx;
  text-align: center;
  background: linear-gradient(135deg, #0066ff, #0055dd);
  border-radius: 50rpx;
  margin-top: 20rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 102, 255, 0.3);
  border: none;
}
.estimate-btn:active {
  opacity: 0.9;
}
.estimate-btn[disabled] {
    background: #2a2a3a !important;
    box-shadow: none;
    color: #ffffff !important;
}
.btn-text {
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 600;
}

/* еә•йғЁ */
.footer {
  text-align: center;
  padding: 40rpx 0;
}
.footer-text {
  font-size: 24rpx;
  color: #444466;
}
