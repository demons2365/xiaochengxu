<!-- pages/lead/lead.wxml -->
<view class="container">
  <!-- 总价展示 -->
  <view class="price-bar">
    <text class="price-label">预估回收价</text>
    <text class="price-value">¥{{totalPrice}}</text>
  </view>

  <!-- 表单 -->
  <view class="card">
    <view class="card-title">📞 填写联系方式</view>
    <text class="card-subtitle">我们将在24小时内联系您安排回收</text>

    <view class="form-group">
      <text class="form-label">手机号 <text class="required">*</text></text>
      <input 
        class="form-input" 
        type="text" 
        placeholder="请输入手机号" 
        value="{{phone}}"
        bindinput="onPhoneInput"
        maxlength="11"
      />
    </view>

    <view class="form-group">
      <text class="form-label">微信号</text>
      <input 
        class="form-input" 
        type="text" 
        placeholder="选填，方便微信联系" 
        value="{{wechat}}"
        bindinput="onWechatInput"
      />
    </view>

    <!-- 配置概览 -->
    <view class="config-preview" wx:if="{{configPreview}}">
      <text class="preview-label">已识别配置：</text>
      <text class="preview-text">{{configPreview}}</text>
    </view>
  </view>

  <!-- 注意事项 -->
  <view class="note-card">
    <text class="note-title">📌 回收须知</text>
    <text class="note-text">1. 回收价仅供参考，最终价格以工程师上门检测为准</text>
    <text class="note-text">2. 我们会安排专业工程师免费上门检测</text>
    <text class="note-text">3. 检测无误后当场付款</text>
  </view>

  <!-- 提交按钮 -->
  <button class="submit-btn" bindtap="onSubmit" disabled="{{!canSubmit}}">
    <text class="btn-text">✅ 提交预约</text>
  </button>

  <view class="footer">
    <text class="footer-text">AI 智能识别 · 实时报价 · 快速回收</text>
  </view>

  <!-- 成功弹窗 -->
  <view class="modal-overlay" wx:if="{{showSuccess}}">
    <view class="modal-content">
      <text class="modal-icon">✅</text>
      <text class="modal-title">提交成功！</text>
      <text class="modal-desc">我们将在24小时内联系您</text>
      <text class="modal-desc">安排上门回收服务</text>
      <button class="modal-btn" bindtap="onDone">完成</button>
    </view>
  </view>
</view>
