/* pages/lead/lead.wxss */
.container {
  min-height: 100vh;
  padding: 30rpx;
  box-sizing: border-box;
}

/* 浠锋牸鏉?*/
.price-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: linear-gradient(135deg, #12122a, #1a1a3a);
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid rgba(0, 102, 255, 0.2);
}
.price-label {
  font-size: 28rpx;
  color: #8888aa;
}
.price-value {
  font-size: 48rpx;
  font-weight: 700;
  color: #00ddff;
}

/* 鍗＄墖 */
.card {
  background: linear-gradient(135deg, #12122a, #1a1a3a);
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid rgba(0, 102, 255, 0.2);
}
.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #ffffff;
  margin-bottom: 8rpx;
}
.card-subtitle {
  font-size: 24rpx;
  color: #6666aa;
  display: block;
  margin-bottom: 30rpx;
}

/* 琛ㄥ崟 */
.form-group {
  margin-bottom: 24rpx;
}
.form-label {
  font-size: 28rpx;
  color: #ccccdd;
  display: block;
  margin-bottom: 10rpx;
}
.required {
  color: #ff6666;
}
.form-input {
  width: 100%;
  height: 80rpx;
  background: #0a0a20;
  border: 2rpx solid #2a2a5a;
  border-radius: 14rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #e0e0e0;
  box-sizing: border-box;
}
.form-input:focus {
  border-color: #0066ff;
}
.form-input::placeholder {
  color: #555577;
}

/* 閰嶇疆棰勮 */
.config-preview {
  margin-top: 20rpx;
  padding: 20rpx;
  background: #0a0a20;
  border-radius: 14rpx;
  border: 1rpx solid #1a1a3a;
}
.preview-label {
  font-size: 26rpx;
  color: #8888cc;
  display: block;
  margin-bottom: 6rpx;
}
.preview-text {
  font-size: 26rpx;
  color: #aaaadd;
  line-height: 1.6;
}

/* 椤荤煡 */
.note-card {
  background: linear-gradient(135deg, #12122a, #1a1a3a);
  border-radius: 20rpx;
  padding: 24rpx 30rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid rgba(255, 200, 0, 0.2);
}
.note-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #ffcc44;
  display: block;
  margin-bottom: 16rpx;
}
.note-text {
  font-size: 26rpx;
  color: #aaaacc;
  line-height: 1.8;
  display: block;
}

/* 鎻愪氦鎸夐挳 */
.submit-btn {
  width: 100%;
  height: 100rpx;
  line-height: 100rpx;
  text-align: center;
  background: linear-gradient(135deg, #00aa66, #008855);
  border-radius: 50rpx;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 32rpx rgba(0, 170, 102, 0.3);
  border: none;
  margin-top: 10rpx;
}
.submit-btn:active {
  opacity: 0.9;
}
.submit-btn[disabled] {
    background: #2a2a3a !important;
    box-shadow: none;
    color: #ffffff !important;
}
.btn-text {
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 600;
}

.footer {
  text-align: center;
  padding: 40rpx 0;
}
.footer-text {
  font-size: 24rpx;
  color: #444466;
}

/* 鎴愬姛寮圭獥 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}
.modal-content {
  width: 560rpx;
  background: #1a1a3a;
  border-radius: 24rpx;
  padding: 50rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  border: 1rpx solid rgba(0, 102, 255, 0.3);
}
.modal-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}
.modal-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 16rpx;
}
.modal-desc {
  font-size: 28rpx;
  color: #8888aa;
  display: block;
  text-align: center;
  line-height: 1.6;
}
.modal-btn {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  background: linear-gradient(135deg, #0066ff, #0055dd);
  border-radius: 40rpx;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
  margin-top: 30rpx;
  border: none;
}
