<!-- pages/result/result.wxml -->
<view class="container">
  <!-- 识别结果头部 -->
  <view class="result-header">
    <view class="total-circle">
      <text class="total-price">¥{{totalPrice}}</text>
      <text class="total-label">预估回收总价</text>
    </view>
  </view>

  <!-- 已识别的硬件 -->
  <view class="section">
    <view class="section-title">🖥️ 已识别硬件清单</view>
    <view class="item-list">
      <view class="item" wx:for="{{items}}" wx:key="index">
        <view class="item-left">
          <text class="item-category">{{item.name}}</text>
          <text class="item-model">{{item.model}}</text>
        </view>
        <view class="item-right">
          <text class="item-price{{item.price === 0 ? ' zero' : ''}}">
            {{item.price === 0 ? '未收录' : '¥' + item.price}}
          </text>
        </view>
      </view>
    </view>
  </view>

  <!-- 未识别的硬件 -->
  <view class="section" wx:if="{{unrecognized.length > 0}}">
    <view class="section-title">⚠️ 未能识别以下信息</view>
    <view class="unrecognized-list">
      <view class="unrecognized-item" wx:for="{{unrecognized}}" wx:key="index">
        <text class="unrecognized-text">{{item.label}}：未能自动识别</text>
        <text class="unrecognized-hint">请补充描述后重新估价</text>
      </view>
    </view>
  </view>

  <!-- 备注 -->
  <view class="note-card">
    <text class="note-text">💡 以上报价为参考回收价，实际价格可能因品牌、成色、配件完整度等因素浮动。</text>
  </view>

  <!-- 操作按钮 -->
  <button class="recycle-btn" bindtap="onRecycle">♻️ 立即回收</button>
  <button class="back-btn" bindtap="onBack">← 重新估价</button>

  <view class="footer">
    <text class="footer-text">AI 智能识别 · 实时报价 · 快速回收</text>
  </view>
</view>
