/* pages/result/result.wxss */
.container {
  min-height: 100vh;
  padding: 30rpx;
  box-sizing: border-box;
}

/* 总价头部 */
.result-header {
  display: flex;
  justify-content: center;
  padding: 40rpx 0 30rpx;
}
.total-circle {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 300rpx;
  height: 300rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #0066ff22, #00ccff22);
  border: 4rpx solid #0066ff;
  box-shadow: 0 0 60rpx rgba(0, 102, 255, 0.2);
}
.total-price {
  font-size: 60rpx;
  font-weight: 700;
  color: #00ddff;
}
.total-label {
  font-size: 26rpx;
  color: #8888aa;
  margin-top: 10rpx;
}

/* 区块 */
.section {
  background: linear-gradient(135deg, #12122a, #1a1a3a);
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid rgba(0, 102, 255, 0.2);
}
.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #ffffff;
  margin-bottom: 20rpx;
}

/* 硬件项 */
.item-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #0a0a20;
  border-radius: 14rpx;
  padding: 20rpx 24rpx;
  border: 1rpx solid #1a1a3a;
}
.item-left {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}
.item-category {
  font-size: 24rpx;
  color: #8888cc;
}
.item-model {
  font-size: 28rpx;
  color: #ffffff;
  font-weight: 500;
}
.item-price {
  font-size: 36rpx;
  font-weight: 700;
  color: #00ddff;
}
.item-price.zero {
  font-size: 28rpx;
  color: #ff6666;
  font-weight: 400;
}

/* 未识别列表 */
.unrecognized-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}
.unrecognized-item {
  background: #0a0a20;
  border-radius: 14rpx;
  padding: 20rpx 24rpx;
  border: 1rpx solid #3a2a2a;
}
.unrecognized-text {
  font-size: 28rpx;
  color: #ff8888;
  display: block;
}
.unrecognized-hint {
  font-size: 24rpx;
  color: #666688;
  margin-top: 6rpx;
  display: block;
}

/* 备注 */
.note-card {
  background: linear-gradient(135deg, #12122a, #1a1a3a);
  border-radius: 20rpx;
  padding: 24rpx 30rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid rgba(255, 200, 0, 0.2);
}
.note-text {
  font-size: 26rpx;
  color: #aaaacc;
  line-height: 1.6;
}

/* 按钮 */
.recycle-btn {
  width: 100%;
  height: 100rpx;
  line-height: 100rpx;
  text-align: center;
  background: linear-gradient(135deg, #00aa66, #008855);
  border-radius: 50rpx;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 32rpx rgba(0, 170, 102, 0.3);
  border: none;
  margin-top: 10rpx;
}
.recycle-btn:active {
  opacity: 0.9;
}
.back-btn {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  background: transparent;
  border-radius: 40rpx;
  color: #6666aa;
  font-size: 28rpx;
  border: 2rpx solid #2a2a5a;
  margin-top: 20rpx;
}
.back-btn:active {
  border-color: #0066ff;
  color: #8888ff;
}

.footer {
  text-align: center;
  padding: 40rpx 0;
}
.footer-text {
  font-size: 24rpx;
  color: #444466;
}
